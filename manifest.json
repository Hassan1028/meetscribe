{
  "manifest_version": 3,
  "name": "MeetScribe — AI Meeting Minutes",
  "version": "1.0.0",
  "description": "Capture mic + tab audio, transcribe, and generate professional Meeting Minutes via Gemini AI.",

  "action": {
    "default_title": "Open MeetScribe"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "tabCapture"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["app.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
